@import url("Variables.uss");

.header-hud {
    flex-direction: row;
    justify-content: space-around;
    align-items: center;
    padding: 10px;
    background-color: rgba(0, 0, 0, 0.4);
    height: 80px;
}

.hud-item {
    flex-direction: column;
    align-items: center;
    margin: 0 5px;
}

.hud-label {
    font-size: 12px;
    color: var(--color-text-secondary);
}

.hud-value {
    font-size: 16px;
    -unity-font-style: bold;
}
