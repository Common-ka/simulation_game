@import url("Variables.uss");

.footer-nav {
    flex-direction: row;
    height: 70px;
    background-color: rgba(0, 0, 0, 0.6);
}

.nav-button {
    flex-grow: 1;
    justify-content: center;
    align-items: center;
    border-top-width: 2px;
    border-top-color: var(--color-border);
}

.nav-button:hover {
    background-color: rgba(255, 255, 255, 0.1);
}
